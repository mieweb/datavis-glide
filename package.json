{
  "name": "wcdatavis",
  "version": "1.2.0",
  "description": "Data visualization library",
  "keywords": [
    "grid",
    "graph",
    "data",
    "visualization"
  ],
  "license": "UNLICENSED",
  "private": true,
  "author": "Taylor Venable <tvenable@mieweb.com>",
  "files": [
    "src/*.js",
    "src/util/*.js",
    "dist/wcdatavis.css"
  ],
  "main": "index.js",
  "browser": "datavis.js",
  "repository": {
    "type": "git",
    "url": "https://github.mieweb.com/datavis/wcdatavis.git"
  },
  "scripts": {
    "lint": "eslint src",
    "test": "mocha -t 10000 tests/selenium/*.js",
    "rollup": "rollup -c rollup.config.js",
    "uglify": "uglifyjs -c -o dist/wcdatavis.min.js dist/wcdatavis.js",
    "http-server": "micro-dev -p 5000 bin/http-server.js"
  },
  "dependencies": {
    "bignumber.js": "9.0.0",
    "flatpickr": "4.6.3",
    "handlebars": "4.7.6",
    "jquery": "3.5.1",
    "jquery-contextmenu": "2.9.2",
    "jquery-ui": "1.12.1",
    "moment": "2.26.0",
    "numeral": "2.0.6",
    "papaparse": "5.2.0",
    "serve-handler": "6.1.2",
    "sprintf-js": "1.1.2",
    "sumoselect": "3.0.5",
    "underscore": "1.10.2"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "12.0.0",
    "@rollup/plugin-node-resolve": "8.0.0",
    "bluebird": "3.7.2",
    "chai": "^4.3.4",
    "chromedriver": "latest",
    "es6-symbol": "3.1.3",
    "eslint": "7.1.0",
    "jsdoc": "3.6.4",
    "jshint": "2.11.1",
    "json5": "2.1.3",
    "lodash": "^4.17.20",
    "mermaid": "8.5.1",
    "micro": "9.3.4",
    "micro-dev": "3.0.0",
    "mocha": "7.2.0",
    "rollup": "2.13.1",
    "selenium-webdriver": "4.0.0-alpha.7",
    "serve": "^11.3.2",
    "uglify-js": "3.9.4"
  }
}
