    "numeral": "^2.0.6",
    "papaparse": "^4.6.3",
    "serve-handler": "^6.1.1",
    "sprintf-js": "^1.1.2",
    "sumoselect": "^3.0.5",
    "underscore": "^1.9.1"
  },
  "devDependencies": {
    "bluebird": "^3.5.5",
    "chai": "^4.2.0",
    "chromedriver": "^79.0.0",
