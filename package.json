    "eslint": "^5.16.0",
    "jsdoc": "^3.6.3",
    "jshint": "^2.10.2",
    "json5": "^2.1.0",
    "lodash": "^4.17.15",
    "mermaid": "^8.4.2",
    "micro": "^9.3.4",
