{
  "data": [
    "$< repeat(500, VALUE) >$",
    {
        "string1": "$< word_dict() >$"
      , "country": "$< choice(['United States', 'Canada', 'Mexico', 'England', 'France', 'Germany', 'Switzerland', 'Japan', 'China', 'South Korea']) >$"
      , "state": "$< state() >$"
      , "int1": "$< random_int(0, 99, output_type='number') >$"
      , "int2": "$< random_int(0, 99, output_type='string') >$"
      , "int3": "$< random_int(0, 99, output_type='string', format='#,##0') >$"
      , "float1": "$< random_float(0, 99, output_type='number') >$"
      , "float2": "$< random_float(0, 99, output_type='string') >$"
      , "float3": "$< random_float(0, 99, output_type='string', format='#,##0.###') >$"
      , "currency1": "$< random_float(0, 9999, output_type='number', fixed=2) >$"
      , "currency2": "$< random_float(0, 9999, output_type='string', format='#,##0.##') >$"
      , "currency3": "$< random_float(0, 9999, output_type='string', format='$#,##0.##') >$"
      , "currency4": "$< random_float(0, 9999, output_type='string', format='$#,##0.##') >$"
      , "date1": "$< random_date(format='yyyy-MM-dd') >$"
      , "date2": "$< random_date(format='MMM d, yyyy') >$"
      , "date3": "$< random_date(format='MM/dd/yy') >$"
    }
  ],
  "typeInfo": [
      { "field": "string1", "type": "string" }
    , { "field": "country", "type": "string" }
    , { "field": "state", "type": "string" }
    , { "field": "int1", "type": "number" }
    , { "field": "int2", "type": "number" }
    , { "field": "int3", "type": "number" }
    , { "field": "float1", "type": "number" }
    , { "field": "float2", "type": "number" }
    , { "field": "float3", "type": "number" }
    , { "field": "currency1", "type": "currency" }
    , { "field": "currency2", "type": "currency" }
    , { "field": "currency3", "type": "currency" }
    , { "field": "currency4", "type": "string" }
    , { "field": "date1", "type": "date" }
    , { "field": "date2", "type": "date", "format": "MMMM D, YYYY" }
    , { "field": "date3", "type": "date", "format": "MM/DD/YY" }
  ]
}
